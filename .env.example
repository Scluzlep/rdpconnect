# 监听地址，设置为 127.0.0.1 配合 Nginx 等反向代理使用
APP_HOST=127.0.0.1

# 监听端口
APP_PORT=8080

# 状态文件保存路径
STATE_FILE=./state.json

# iptables 专用链名称，所有规则会存放在这里
IPTABLES_CHAIN=RDP_JIFANG

# 最长放行时间保护（分钟）
MAX_DURATION_MINUTES=180

# 空闲断开时间（分钟），当 TCP 和 UDP 均无连接时，闲置多久后回收规则
IDLE_CLOSE_MINUTES=3

# 初始宽限期（分钟），开启端口后的这段时间内即使无连接也不会被闲置回收
INITIAL_GRACE_MINUTES=10

# 后台巡检扫描间隔（秒）
SCAN_INTERVAL_SECONDS=10

# 是否信任反向代理传递的真实 IP (X-Forwarded-For, CF-Connecting-IP 等)
TRUST_PROXY=true
